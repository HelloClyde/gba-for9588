+  ram_used = (u32)(ram_translation_ptr - ram_translation_cache);
+  if (rom_used < (ROM_TRANSLATION_CACHE_SIZE * 3U) / 4U &&
+      ram_used < (RAM_TRANSLATION_CACHE_SIZE * 3U) / 4U)
+    return;
